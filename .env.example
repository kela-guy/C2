# Cesium Ion access token — restrict by domain on cesium.com/ion settings.
# Cesium is the production-default map backend (Phase 8 cutover; the legacy
# Mapbox stack was removed in Phase 9). Effectively required for normal
# development. Also REQUIRED for the /onboarding concept-video scene: it
# streams Google Photorealistic 3D Tiles through Cesium Ion (free account at
# https://ion.cesium.com — make sure "Google Photorealistic 3D Tiles" is
# added to your assets). Without a token the map falls back to a flat
# dark raster map.
VITE_CESIUM_ION_TOKEN="eyJhbGciOiJIUzI1NiIs..."

# Central Icons license key — required only at install time to fetch the
# private @central-icons-react/* packages. Export it in your shell BEFORE
# running `pnpm install`, e.g.:
#   export CENTRAL_LICENSE_KEY="your-key-here"
#   pnpm install
# Not consumed at runtime; safe to omit from the production runtime env.
CENTRAL_LICENSE_KEY="00000000-0000-0000-0000-000000000000"

# Set to "1" to expose the internal lab/review routes (/styleguide-legacy,
# /devices-lab, /onboarding, /video-hud-sandbox, /pathfinder-sandbox,
# /handoff) on a deployed build. Local dev always shows them. Leave unset
# for operator-facing production.
VITE_SHOW_LABS=""
